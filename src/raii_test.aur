class MyObject {
    var id;
    func drop() {
        print_str("Destructor called for object with ID:");
        print(this.id);
        return 0;
    }
}

func test_scope() {
    print_str("Entering test_scope");
    var obj = new MyObject();
    obj.id = 123;
    print_str("Exiting test_scope");
    return 0;
}

test_scope();
print_str("Back in main");
