class UserController {
    func getUser(id) {
        var users = [
            "{\"error\": \"Lutfen 1 veya 2 nolu id girin\"}",
            "{\"id\": 1, \"name\": \"Alper\", \"status\": \"Active\", \"db\": \"Array\"}",
            "{\"id\": 2, \"name\": \"Aura AI\", \"status\": \"Online\", \"db\": \"Array\"}",
            "{\"id\": 3, \"name\": \"Guest\", \"status\": \"Offline\", \"db\": \"Array\"}"
        ];
        
        if (id > 3) {
            return "{\"status\": \"error\", \"message\": \"User not found in Aura DB\"}";
        }
        
        // Veriyi direkt diziden çekiyoruz!
        return users[id];
    }
}

print_str("Aura Veritabani (Array) API Sunucusu Hazir!");
print_str("Diziden veri cekmek icin:");
print_str("- http://localhost:8080/getUser?id=1");
print_str("- http://localhost:8080/getUser?id=2");

var api = new UserController();
api_listen(8080, api);
